{
  "name": "parliament-attendance-blockchain",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --dir backend dev",
    "build": "pnpm --dir backend build",
    "test": "pnpm --dir backend test",
    "test:integration": "pnpm --dir backend test:integration",
    "test:coverage": "pnpm --dir backend test:coverage",
    "seed": "pnpm --dir backend seed",
    "prisma": "pnpm --dir backend prisma"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "@types/react",
        "react",
        "react-dom"
      ]
    }
  }
}
