generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DEPUTY
  AUDITOR
}

enum SessionStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum SessionType {
  PLENARY
  COMMITTEE
  SUBCOMMITTEE
  VOTING
  WORKGROUP
  OTHER
}

enum AttendanceStatus {
  PENDING
  SUBMITTED
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         UserRole
  deputyId     Int?
  deputy       Deputy?  @relation(fields: [deputyId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
}

model Deputy {
  id              Int      @id @default(autoincrement())
  publicIdentifier String  @unique
  name            String
  party           String
  electoralCircle String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users             User[]
  attendanceRecords AttendanceRecord[]
}

model ParliamentarySession {
  id                    Int           @id @default(autoincrement())
  title                 String
  sessionType           SessionType
  locationId            Int
  location              AuthorizedLocation @relation(fields: [locationId], references: [id])
  scheduledStart        DateTime
  scheduledEnd          DateTime
  checkinStart          DateTime
  checkinEnd            DateTime
  status                SessionStatus @default(DRAFT)
  allowMultipleCheckins Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  attendanceRecords AttendanceRecord[]
}

model AuthorizedLocation {
  id              Int      @id @default(autoincrement())
  name            String
  latitude        Float
  longitude       Float
  radiusMeters    Int
  allowedIpRanges Json
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions ParliamentarySession[]
}

model ValidationPolicy {
  id        String   @id
  name      String
  version   Int
  rulesJson Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendanceRecords AttendanceRecord[]
}

model AttendanceRecord {
  id                    Int              @id @default(autoincrement())
  deputyId              Int
  deputy                Deputy           @relation(fields: [deputyId], references: [id])
  sessionId             Int
  session               ParliamentarySession @relation(fields: [sessionId], references: [id])
  registeredAt          DateTime
  clientRequestId       String           @unique
  clientIp              String
  gpsLatitude           Float?
  gpsLongitude          Float?
  gpsAccuracyMeters     Float?
  validationPolicyId    String
  validationPolicy      ValidationPolicy @relation(fields: [validationPolicyId], references: [id])
  validationDetailsJson Json?
  applicationId         String?
  applicationVersion    String?
  hashAlgorithm         String?
  txHash                String?
  blockNumber           BigInt?
  contractAddress       String?
  status                AttendanceStatus @default(PENDING)
  failureReason         String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  auditLogs AuditLog[]

  @@index([deputyId, sessionId])
  @@index([sessionId])
}

model AuditLog {
  id                 Int      @id @default(autoincrement())
  eventType          String
  actorUserId        Int?
  actorUser          User?    @relation(fields: [actorUserId], references: [id])
  attendanceRecordId Int?
  attendanceRecord   AttendanceRecord? @relation(fields: [attendanceRecordId], references: [id])
  detailsJson        Json?
  createdAt          DateTime @default(now())
}
