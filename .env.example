NODE_ENV=development
HOST=127.0.0.1
PORT=3000
DATABASE_URL=postgresql://attendance:attendance@localhost:5432/attendance
JWT_SECRET=replace-me
JWT_EXPIRES_IN_SECONDS=3600
APP_PRIVATE_KEY=replace-with-0x-prefixed-32-byte-secp256k1-private-key
MAX_GPS_ACCURACY_METERS=100
DEFAULT_CHECKIN_RADIUS_METERS=100
HASH_ALGORITHM=keccak256
BLOCKCHAIN_MODE=mock
APPLICATION_ID=attendance-backend
APPLICATION_VERSION=1.0.0
