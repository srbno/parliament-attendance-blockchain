meta {
  name: Create Location
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/locations
  body: json
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
